ANTHROPIC_API_KEY=
TRADING_212_API_KEY_ID=
TRADING_212_API_KEY_SECRET=
TRADING_212_MODE=demo

# Postgres connection string (docker-compose default below)
DATABASE_URL=postgresql://trader:trader@localhost:5432/trader

# Comma-separated T212 ticker symbols (check T212 instrument names — _l suffix = LSE)
TRADE_UNIVERSE=AAPL,MSFT,GOOGL,AMZN,TSLA,NVDA,VOD_l,BP_l,SHEL_l,RIO_l,BARC_l,LLOY_l,AZN_l

# How often to run a cycle during market hours (ms). Default: 15 minutes
TRADE_INTERVAL_MS=900000

# Hard budget cap in EUR
MAX_BUDGET_EUR=100

# Max fraction of budget in a single position (0.25 = 25%)
MAX_POSITION_PCT=0.25

# Daily portfolio loss that triggers a trading halt (0.10 = 10%)
DAILY_LOSS_LIMIT_PCT=0.10
