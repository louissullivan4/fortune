# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/trader

# ── JWT Authentication ───────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=

# ── API key encryption (AES-256-GCM) ────────────────────────────────────────
# Must be exactly 64 hex characters (32 bytes). Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ── Email (Gmail App Password) ───────────────────────────────────────────────
# Used for sending invite emails and password reset emails.
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=

# ── Frontend URL (for email links) ───────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database reset (dev only) ────────────────────────────────────────────────
# Set to true to wipe and recreate the database on every startup.
WIPE_DB_ON_START=false
